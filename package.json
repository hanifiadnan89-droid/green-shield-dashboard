{
  "name": "green-shield-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n SERVER,CLIENT -c cyan,green \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "install:all": "npm install && npm install --prefix server && npm install --prefix client",
    "build": "npm run build --prefix client",
    "render:build": "npm run install:all && npm run playwright:install --prefix server && npm run build",
    "start": "npm start --prefix server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-spring/web": "^10.1.0",
    "@rive-app/react-canvas": "^4.28.6",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lottie-react": "^2.4.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "react-countup": "^6.5.3",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "usehooks-ts": "^3.1.1"
  }
}
