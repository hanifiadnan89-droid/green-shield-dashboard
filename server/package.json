{
  "name": "green-shield-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch index.js",
    "start": "node index.js",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:migrate:status": "node scripts/db-migrate-status.mjs",
    "db:backfill:append-only": "node scripts/backfill-append-only-logs.mjs",
    "db:reconcile:append-only": "node scripts/reconcile-append-only-logs.mjs",
    "db:validate:append-only": "node scripts/validate-append-only-db-enablement.mjs",
    "db:validate:append-only:ci": "node scripts/run-append-only-validation-ci.mjs",
    "db:exercise:append-only:staging": "node scripts/exercise-append-only-dual-write-staging.mjs",
    "db:validate:append-only:burn-in:staging": "node scripts/validate-append-only-burn-in-staging.mjs",
    "playwright:install": "PLAYWRIGHT_BROWSERS_PATH=0 npx playwright install chromium",
    "playwright:install:render": "PLAYWRIGHT_BROWSERS_PATH=0 npx playwright install chromium",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^140.0.1",
    "helmet": "^8.2.0",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "officeparser": "^7.2.2",
    "openai": "^6.45.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "twilio": "^6.0.2",
    "xlsx": "^0.18.5",
    "youtube-transcript": "^1.3.1"
  },
  "devDependencies": {
    "pdfjs-dist": "^4.10.38",
    "vitest": "^1.6.1"
  }
}
