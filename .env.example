# ─────────────────────────────────────────────────────────────────────────────
# Green Shield Dashboard — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── GOOGLE SERVICE ACCOUNT ───────────────────────────────────────────────────
# Paste the full contents of your service account JSON key as a single line.
# How to get this:
#   1. Go to console.cloud.google.com → APIs & Services → Credentials
#   2. Create Service Account → Download JSON key
#   3. Share your "Lead Responses" Google Sheet with the service account email
#   4. Paste the entire JSON here (keep it on one line, or use the file path option below)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# Alternative: Point to the JSON file instead (uncomment one or the other)
# GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/your-service-account.json

# ── GOOGLE SHEETS ─────────────────────────────────────────────────────────────
# Your "Lead Responses" spreadsheet ID (already pre-filled from inspection)
SHEET_ID=1hneyXzxNqHDM-AfNs5-c1Qp7jqBeHfpKKsYbf_62obk
SHEET_NAME=Lead Responses

# Action/Error Lists — Activity Log open error tasks (separate from Lead Responses sheet)
ERROR_LIST_SHEET_ID=1faT6OQJ1we6RkjfmqQFhcQk9OO5ohoFa4_JkwtoiDH0
ERROR_LIST_SHEET_NAME=Action/Error Lists
ERROR_LIST_HEADER_ROW=11
ERROR_LIST_ASSIGNEE=AH
# Error list sheet is read-only — Complete is stored locally in server/data/
# (does not write to the Google Sheet). Service account needs Viewer access only.

# ── n8n WEBHOOKS ──────────────────────────────────────────────────────────────
# Your n8n instance base URL
N8N_BASE_URL=https://leadsales.app.n8n.cloud

# Webhook path for Lead Email Responder (no auth required)
N8N_LEAD_WEBHOOK_PATH=/webhook/lead-response

# Optional: n8n API key (enables workflow status fetching, not required)
# Get from: n8n → Settings → n8n API
N8N_API_KEY=

# ── GOOGLE DRIVE (QUOTES) ────────────────────────────────────────────────────
# IDs of your quote files in Google Drive
# Leave blank to use the placeholder links — you can fill these in later
QUOTE_NORMAL_DRIVE_ID=
QUOTE_DISCOUNTED_DRIVE_ID=

# ── TEST / LIVE MODE ──────────────────────────────────────────────────────────
# TEST_MODE=true  → Shows what WOULD happen — no real sends, no real sheet writes
# TEST_MODE=false → LIVE — sends real messages and updates the real sheet
TEST_MODE=true

# ── GMAIL (direct quote email — no n8n involved) ─────────────────────────────
# Used to email quote PDFs directly to customers from the CRM.
# How to get an App Password:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to myaccount.google.com → Security → 2-Step Verification → App passwords
#   3. Create one named "Green Shield CRM" — paste the 16-char code below
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── AGREEMENT E-SIGNING (RIT and future agreements) ───────────────────────────
# Public URL customers use to open /sign/:token (set to your deployed dashboard URL)
# PUBLIC_APP_URL=https://green-shield-dashboard.onrender.com
# Email that receives signed agreement notifications (defaults to GMAIL_USER)
# AGREEMENT_SIGNING_NOTIFY_EMAIL=ahanifi@gshieldpest.com
# AGREEMENT_SIGNING_TTL_DAYS=30

# ── GOOGLE MAPS (Route Finder satellite route preview) ───────────────────────
# Enable Maps JavaScript API in Google Cloud Console. Restrict key to your domain.
# ── GOOGLE MAPS (Route Finder satellite route preview) ───────────────────────
# Enable Maps JavaScript API in Google Cloud Console. Restrict key to your domain.
# Browser Maps JavaScript API key (inlined at CLIENT BUILD TIME by Vite — redeploy after changing).
# On Render: set on the service and trigger a new deploy so `npm run build` sees it.
# Restrict HTTP referrers to https://green-shield-dashboard.onrender.com/* and localhost for dev.
# VITE_GOOGLE_MAPS_API_KEY=your_browser_maps_api_key

# ── GOOGLE ROUTES (Route Finder road-based drive time — SERVER ONLY) ─────────
# Enable Routes API in Google Cloud Console. Create a separate server-side key.
# Restrict the key to Routes API only. Do NOT use the browser Maps JS key here.
# GOOGLE_ROUTES_API_KEY=your_server_routes_api_key

# Route Finder Google Routes API usage limits (server-enforced)
# ROUTES_ENABLE_ROAD_TIMING=true
# ROUTES_PREFILTER_TOP_ROUTES=5
# ROUTES_MAX_ELEMENTS_PER_SEARCH=250
# ROUTES_MAX_ELEMENTS_PER_ROUTE=50
# ROUTES_MAX_ELEMENTS_PER_DAY=1000
# ROUTES_MATRIX_CACHE_TTL_MINUTES=60
# ROUTES_POLYLINE_ON_DETAIL_ONLY=true

# Route Finder V2 scoring (client build-time flag — redeploy client after changing)
# When true, scoreSingleDate() uses routeFinderScoringV2.js (scaffold delegates to legacy staged scorer for now).
# VITE_ROUTE_FINDER_V2_SCORING=false

# ── INTAKE SALES FLOW ─────────────────────────────────────────────────────────
# Client nav + pages (redeploy client after changing)
# VITE_INTAKE_ENABLED=true

# Server Intake API routes (address validation, geocoding, weather proxy)
# INTAKE_ENABLED=true

# Server-side Google APIs for Intake (Address Validation, Geocoding, Weather).
# Falls back to GOOGLE_ROUTES_API_KEY when unset.
# GOOGLE_MAPS_SERVER_API_KEY=your_server_maps_key

# ── AGREEMENT PDF FEATURE FLAGS ───────────────────────────────────────────────
# When true, Insect Quarterly uses the vector PDF builder (Bed Bug design system).
# Legacy AcroForm overlay remains the default until QA completes.
# Insect Quarterly vector PDF (enabled by default; set false for legacy AcroForm)
# INSECT_QUARTERLY_VECTOR_PDF=false

# When true, Rodent & Insect Triannual uses the vector PDF builder (Bed Bug design system).
# Legacy AcroForm overlay remains the default until QA completes.
# RODENT_INSECT_TRIANNUAL_VECTOR_PDF=true

# Set to false to use the legacy Service Agreements.pdf page for Tick & Mosquito Monthly.
# TICK_MOSQUITO_MONTHLY_VECTOR_PDF=false

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3001
